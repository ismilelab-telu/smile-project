#:schema https://developers.openai.com/codex/config-schema.json

# Shared Codex defaults for this repository.

model = "gpt-5.5"
model_context_window = 900000
model_auto_compact_token_limit = 800000
model_reasoning_effort = "xhigh"
plan_mode_reasoning_effort = "xhigh"
personality = "friendly"
steer = true
web_search = "disabled"
suppress_unstable_features_warning = true
approval_policy = "never"
sandbox_mode = "danger-full-access"

[agents.default]
description = "General task executor"
config_file = "agents/custom-default.toml"

[agents.explorer]
description = "Codebase explorer for read-heavy tasks."
config_file = "agents/custom-explorer.toml"

[agents.review-commit]
description = "Inspect working-tree changes, generate conventional commit messages, and commit without pushing."
config_file = "agents/review-commit.toml"

[features]
unified_exec = true
shell_snapshot = true
collaboration_modes = true
multi_agent = true
goal = true
js_repl = true

[mcp_servers.shadcn]
command = "npx"
args = ["shadcn@latest", "mcp"]
startup_timeout_sec = 20
enabled = false

[mcp_servers.chrome-devtools]
command = "npx"
args = ["chrome-devtools-mcp@latest", "--headless=true"]
enabled = false

[mcp_servers.exa]
url = "https://mcp.exa.ai/mcp?tools=web_search_exa,web_search_advanced_exa,get_code_context_exa,crawling_exa,company_research_exa,people_search_exa,deep_researcher_start,deep_researcher_check,deep_search_exa"
enabled = true

[mcp_servers.aws-knowledge]
url = "https://knowledge-mcp.global.api.aws"
enabled = true

[mcp_servers.aws-mcp]
command = "uvx"
args = [
  "mcp-proxy-for-aws@latest",
  "https://aws-mcp.us-east-1.api.aws/mcp",
  "--profile",
  "smile-dev",
  "--region",
  "ap-southeast-1",
  "--metadata",
  "AWS_REGION=ap-southeast-1",
  "--read-only",
  "--log-level",
  "ERROR",
]
startup_timeout_sec = 60
enabled = true

[mcp_servers.awslabs-aws-documentation]
command = "uvx"
args = ["awslabs.aws-documentation-mcp-server@latest"]
startup_timeout_sec = 60
enabled = true

[mcp_servers.awslabs-aws-documentation.env]
AWS_DOCUMENTATION_PARTITION = "aws"
FASTMCP_LOG_LEVEL = "ERROR"

[mcp_servers.awslabs-aws-serverless]
command = "uvx"
args = ["awslabs.aws-serverless-mcp-server@latest"]
startup_timeout_sec = 60
enabled = true

[mcp_servers.awslabs-aws-serverless.env]
AWS_PROFILE = "smile-dev"
AWS_REGION = "ap-southeast-1"
FASTMCP_LOG_LEVEL = "ERROR"

[mcp_servers.awslabs-cloudwatch]
command = "uvx"
args = ["awslabs.cloudwatch-mcp-server@latest"]
startup_timeout_sec = 60
enabled = true

[mcp_servers.awslabs-cloudwatch.env]
AWS_PROFILE = "smile-dev"
AWS_REGION = "ap-southeast-1"
FASTMCP_LOG_LEVEL = "ERROR"

[mcp_servers.awslabs-dynamodb-mcp-server]
command = "uvx"
args = ["awslabs.dynamodb-mcp-server@latest"]
startup_timeout_sec = 60
enabled = true

[mcp_servers.awslabs-dynamodb-mcp-server.env]
DDB-MCP-READONLY = "true"
AWS_PROFILE = "smile-dev"
AWS_REGION = "ap-southeast-1"
FASTMCP_LOG_LEVEL = "ERROR"

# Keep the Resend API key in ~/.codex/secrets/smile-project-resend-mcp.env.
[mcp_servers.resend]
command = "sh"
args = [
  "-lc",
  "set -a; . \"$HOME/.codex/secrets/smile-project-resend-mcp.env\"; set +a; exec npx -y resend-mcp",
]
startup_timeout_sec = 120
enabled = true

[mcp_servers.notion]
url = "https://mcp.notion.com/mcp"
enabled = false

[mcp_servers.playwright]
command = "npx"
args = ["@playwright/mcp@latest", "--extension"]
enabled = true
